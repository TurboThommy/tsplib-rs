{
  "name": "tsp-problem-editor",
  "version": "1.0.0",
  "private": true,
  "description": "Local TSP problem viewer for the tsplib-rs backend.",
  "scripts": {
    "start": "node server.js",
    "start:frontend": "node -e \"process.env.TSPLIB_AUTO_START_BACKEND='0'; require('./server.js')\"",
    "start:backend": "cd .. && cargo run -p tsplib-server"
  },
  "engines": {
    "node": ">=18"
  }
}
