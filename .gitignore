// Ignore the target directory, which contains build artifacts and should not be included in version control.
/target

// Ignore the Cargo.lock file, which is generated automatically by Cargo and should not be included in version control for libraries.
/Cargo.lock

// Ignore local notes and test instances
personal_notes.md
/data/test_data

// Ignore Node.js dependencies for the local frontend adapter.
/frontend/node_modules
npm-debug.log*

// Ignore local .vscode settings
.vscode